{
  "name": "@agney/playground",
  "version": "2.0.0",
  "private": false,
  "description": "A simple playground for HTML, CSS and JavaScript supporting module imports.",
  "keywords": [
    "editor",
    "playground",
    "react"
  ],
  "bugs": {
    "url": "https://github.com/agneym/playground/issues"
  },
  "license": "MIT",
  "author": "Agney Menon <agney@outlook.in> (@agneymenon)",
  "repository": {
    "type": "git",
    "url": "https://github.com/agneym/playground"
  },
  "source": "src/Playground.tsx",
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "dist/Playground.js",
  "types": "dist/Playground.d.ts",
  "exports": {
    ".": {
      "types": "./dist/Playground.d.ts",
      "import": "./dist/Playground.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "tsdown --watch",
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build",
    "type:check": "tsgo --noEmit"
  },
  "dependencies": {
    "@agney/react-inspector": "^4.0.0",
    "@reach/auto-id": "^0.18.0",
    "@reach/tabs": "^0.18.0",
    "goober": "^2.0.41",
    "lodash.merge": "^4.6.2",
    "prism-react-renderer": "^2.4.1",
    "react-simple-code-editor": "^0.14.1"
  },
  "devDependencies": {
    "@rollup/plugin-babel": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/lodash": "^4.17.24",
    "@types/lodash-es": "^4.17.5",
    "@types/lodash.merge": "^4.6.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-inspector": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "jsdom": "^29.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsdown": "^0.21.10",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  }
}
